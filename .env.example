# Puertos locales (docker compose). Coolify usa 8000 en el host; no reutilizar ese puerto.
BACKEND_PORT=8001
FRONTEND_PORT=3000

# URLs que ve el navegador (Coolify: dominios públicos)
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws

# Orígenes permitidos por CORS (separados por coma)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Ejemplo producción Coolify:
# NEXT_PUBLIC_API_URL=https://api.tudominio.com
# NEXT_PUBLIC_WS_URL=wss://api.tudominio.com/ws
# CORS_ORIGINS=https://meme.tudominio.com
